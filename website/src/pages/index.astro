---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE, TELEGRAM_CHANNEL_URL } from '../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';
import '../styles/home.css';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const recentPosts = posts.slice(0, 3);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  <!-- Product JSON‑LD for rich results -->
  <script type="application/ld+json">
  {`
    {
      "@context": "https://schema.org",
      "@type": "Product",
      "name": "Loot Deals",
      "description": "AI‑verified discount deals from Amazon",
      "brand": { "@type": "Brand", "name": "Budget Deals" },
      "offers": {
        "@type": "Offer",
        "priceCurrency": "INR",
        "price": "0",
        "availability": "https://schema.org/InStock",
        "url": "${TELEGRAM_CHANNEL_URL}"
      }
    }
  `}
  </script>

	</head>
	<body>
		<Header />
		<main>
			<div class="hero-banner">
				<span class="loot-tag">🔥 Trending Now</span>
				<h1>Loot Deals & Extreme Discounts!</h1>
				<p>{SITE_DESCRIPTION}</p>
				<p>🚀 Join 15,000+ shoppers on <a href={TELEGRAM_CHANNEL_URL}>Telegram</a> | <a href="https://amzn.to/your_aff_id" target="_blank" rel="nofollow">Shop on Amazon</a></p>
			</div>
      <!-- Newsletter capture -->
      <section class="newsletter" style="margin-top:2rem; text-align:center;">
        <h3>Get Fresh Deals in Your Inbox</h3>
        <form action="https://example.com/subscribe" method="POST" style="display:inline-block;">
          <input type="email" name="email" placeholder="you@example.com" required style="padding:0.5rem;border-radius:4px;border:1px solid #ccc;" />
          <button type="submit" style="margin-left:0.5rem;padding:0.5rem 1rem;background:#ff9900;color:#fff;border:none;border-radius:4px;cursor:pointer;">Subscribe</button>
        </form>
      </section>

			<section>
				<h2>🔥 Latest Loot Verified by AI</h2>
				<div class="deals-grid">
					{recentPosts.map((post) => (
						<div class="deal-card">
							<a href={`/blog/${post.id}/`}>
								<img src={post.data.heroImage} alt={post.data.title} loading="lazy" />
								<div class="deal-info">
									<h3>{post.data.title}</h3>
									<span class="buy-btn" data-variant="A">View Detailed Review</span>
								</div>
							</a>
						</div>
					))}
				</div>
			</section>

			<section style="margin-top: 4rem;">
				<h2>About Budget Deals India</h2>
				<p>
					We are India's #1 AI-powered deals curator. We scan thousands of Amazon products every hour
					to find genuine price drops and loot offers. From electronics to daily essentials, we bring you 
					the best prices verified for quality and trust.
				</p>
			</section>
		</main>
		<Footer />
	</body>
</html>
