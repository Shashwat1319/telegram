---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>🚀 Welcome to Budget Deals India!</h1>
			<p>
				Your one-stop destination for the <b>craziest loot deals</b> from Amazon India. We track price drops 24/7 
				to bring you verified bargains that save you thousands.
			</p>
			<p>
				From high-performance ACs to kitchen essentials under ₹99, we cover it all. Every deal is analyzed by our
				AI engine to ensure it's a genuine "Loot" before we post it here.
			</p>
			<p><b>Why follow us?</b></p>
			<ul>
				<li><b>Verified Loots</b>: No fake discounts, only real price drops.</li>
				<li><b>Flash Notifications</b>: We post the best deals on our Telegram channel first.</li>
				<li><b>Daily Updates</b>: 10+ new budget deals added every single day.</li>
			</ul>
			<p>
				🔥 <b>JOIN OUR TELEGRAM CHANNEL FOR INSTANT ALERTS</b> 🔥<br/>
				Don't miss the 1-minute flash deals. Join <a href="https://t.me/budgetdeals_india">@budgetdeals_india</a> now!
			</p>
		</main>
		<Footer />
	</body>
</html>
