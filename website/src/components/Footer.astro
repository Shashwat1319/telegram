---
import { TELEGRAM_CHANNEL_URL } from '../consts';
const today = new Date();
---

<footer>
	<div class="footer-grid">
		<div class="footer-section">
			<h3>Budget Deals India</h3>
			<p>Daily verified Amazon India deals, price drops &amp; loot offers for smart shoppers.</p>
		</div>
		<div class="footer-section">
			<h3>Quick Links</h3>
			<a href="/deals">Latest Deals</a>
			<a href="/blog">Blog</a>
			<a href="/categories">Categories</a>
			<a href="/about">About</a>
			<a href="/privacy">Privacy</a>
		</div>
		<div class="footer-section">
			<h3>Get Deal Alerts</h3>
			<form class="footer-form" onsubmit="handleFooterSubscribe(event)">
				<input type="email" id="footerEmail" required placeholder="your@email.com">
				<button type="submit">Subscribe</button>
			</form>
			<p id="footerStatus" class="footer-status"></p>
			<a href={TELEGRAM_CHANNEL_URL} target="_blank" class="tg-link">
				Join Telegram Channel →
			</a>
		</div>
	</div>
	<div class="footer-bottom">
		&copy; {today.getFullYear()} Budget Deals India. All rights reserved.
	</div>
</footer>

<script>
	async function handleFooterSubscribe(e) {
		e.preventDefault();
		const email = document.getElementById('footerEmail').value;
		const status = document.getElementById('footerStatus');
		const btn = e.target.querySelector('button');
		btn.textContent = '...';
		btn.disabled = true;
		try {
			const res = await fetch('/.netlify/functions/subscribe', {
				method: 'POST',
				headers: { 'Content-Type': 'application/json' },
				body: JSON.stringify({ email })
			});
			const data = await res.json();
			status.textContent = res.ok ? '✅ Subscribed!' : (data.error || 'Error');
			status.style.color = res.ok ? '#22c55e' : '#ef4444';
			if (res.ok) document.getElementById('footerEmail').value = '';
		} catch {
			status.textContent = 'Network error';
			status.style.color = '#ef4444';
		}
		btn.textContent = 'Subscribe';
		btn.disabled = false;
	}
</script>

<style>
	footer {
		background: #1e293b;
		color: #cbd5e1;
		padding: 3em 1em 2em;
		margin-top: 3em;
	}
	.footer-grid {
		max-width: 1000px;
		margin: 0 auto;
		display: grid;
		grid-template-columns: 1fr 1fr 1fr;
		gap: 2em;
		text-align: left;
	}
	.footer-section h3 {
		color: #f1f5f9;
		font-size: 1rem;
		margin-bottom: 0.75em;
	}
	.footer-section p {
		font-size: 0.85rem;
		line-height: 1.5;
		color: #94a3b8;
	}
	.footer-section a {
		display: block;
		color: #94a3b8;
		font-size: 0.85rem;
		text-decoration: none;
		margin-bottom: 0.4em;
	}
	.footer-section a:hover {
		color: #22d3ee;
	}
	.footer-form {
		display: flex;
		gap: 0.5em;
	}
	.footer-form input {
		flex: 1;
		padding: 0.5em 0.75em;
		border: 1px solid #475569;
		border-radius: 6px;
		background: #0f172a;
		color: #e2e8f0;
		font-size: 0.85rem;
		outline: none;
	}
	.footer-form input:focus {
		border-color: #22d3ee;
	}
	.footer-form button {
		background: #22d3ee;
		color: #0f172a;
		border: none;
		padding: 0.5em 1em;
		border-radius: 6px;
		font-weight: 600;
		font-size: 0.85rem;
		cursor: pointer;
		white-space: nowrap;
	}
	.footer-form button:hover {
		background: #06b6d4;
	}
	.footer-status {
		font-size: 0.8rem;
		margin-top: 0.5em;
		min-height: 1.2em;
	}
	.tg-link {
		margin-top: 1em !important;
		color: #22d3ee !important;
		font-weight: 600;
	}
	.footer-bottom {
		text-align: center;
		padding-top: 2em;
		margin-top: 2em;
		border-top: 1px solid #334155;
		font-size: 0.8rem;
		color: #64748b;
	}
	@media (max-width: 768px) {
		.footer-grid {
			grid-template-columns: 1fr;
			text-align: center;
		}
		.footer-form {
			max-width: 300px;
			margin: 0 auto;
		}
	}
</style>
