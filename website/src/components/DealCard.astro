---
interface Props {
  title: string;
  price: string;
  mrp: string;
  discount: string;
  image: string;
  buyLink: string;
  category: string;
  rating?: string;
  description?: string;
  slug?: string;
}

const { title, price, mrp, discount, image, buyLink, category, rating, description, slug } = Astro.props;
---

<article class="deal-card group bg-white rounded-xl border border-gray-200 overflow-hidden shadow-sm hover:shadow-lg transition-shadow duration-300 flex flex-col h-full">
  <div class="relative aspect-square bg-gray-100 overflow-hidden">
    {image ? (
      <img 
        src={image} 
        alt={title} 
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
        loading="lazy"
        decoding="async"
      />
    ) : (
      <div class="w-full h-full flex items-center justify-center text-gray-400">
        <svg class="w-16 h-16" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
      </div>
    )}
    
    <div class="absolute top-2 left-2 flex flex-col gap-1">
      <span class="bg-orange-600 text-white text-xs font-bold px-2 py-1 rounded">{discount} OFF</span>
      <span class="bg-black/70 text-white text-xs px-2 py-1 rounded capitalize">{category}</span>
    </div>
    
    {rating && (
      <div class="absolute bottom-2 right-2 bg-white/90 backdrop-blur text-xs font-medium px-2 py-1 rounded flex items-center gap-1">
        <svg class="w-4 h-4 text-yellow-500" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
          <path d="M9.049 2.927c.3-.921 1.603-.921 1.92 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
        </svg>
        {rating}
      </div>
    )}
  </div>
  
  <div class="p-4 flex flex-col flex-1">
    {slug ? (
      <a href={`/deal/${slug}/`} class="no-underline">
        <h3 class="font-semibold text-gray-900 line-clamp-2 mb-2 group-hover:text-orange-600 transition-colors">{title}</h3>
      </a>
    ) : (
      <h3 class="font-semibold text-gray-900 line-clamp-2 mb-2">{title}</h3>
    )}
    
    {description && (
      <p class="text-sm text-gray-500 line-clamp-2 mb-3 flex-1">{description}</p>
    )}
    
    <div class="flex items-baseline gap-2 mb-3">
      <span class="text-xl font-bold text-orange-600">{price}</span>
      <span class="text-sm text-gray-400 line-through">{mrp}</span>
    </div>

    <div class="flex gap-2 mt-auto">
      <a 
        href={buyLink} 
        target="_blank" 
        rel="noopener sponsored"
        class="flex-1 bg-orange-600 text-white text-center font-semibold py-3 rounded-lg hover:bg-orange-700 transition-colors focus:outline-none focus:ring-2 focus:ring-orange-500 focus:ring-offset-2 text-sm"
      >
        Grab Deal →
      </a>
      {slug && (
        <a 
          href={`/deal/${slug}/`}
          class="px-3 py-3 border border-gray-200 text-gray-600 text-center font-medium rounded-lg hover:border-orange-300 hover:text-orange-600 transition-colors text-sm"
        >
          Details
        </a>
      )}
    </div>
  </div>
</article>